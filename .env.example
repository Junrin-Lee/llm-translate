# Firefox self-distribution (unlisted) signing — used by `web-ext sign`.
# See docs/INSTALL.md → "Install on Firefox" → "Option C: Self-distribution".
#
# Quick start:
#   cp .env.example .env      # then fill in the two values below
#
# Generate the credentials at:
#   https://addons.mozilla.org/developers/addon/api/key/
# (requires a free Firefox account). This file is safe to commit; .env is git-ignored.

# JWT issuer, e.g. user:12345678:123
WEB_EXT_API_KEY=

# JWT secret — shown only once on the AMO page; keep it out of git.
WEB_EXT_API_SECRET=
