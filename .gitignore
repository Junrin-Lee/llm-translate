# npm lockfile — this repo is pnpm-only (packageManager: pnpm). Keep any stray
# package-lock.json out of git and out of the AMO sources zip so a reviewer
# can't accidentally `npm install` a divergent tree; pnpm-lock.yaml is canonical.
package-lock.json
.output
.wxt
dist
coverage
stats.html
*.zip
test-results
playwright-report
.playwright
.DS_Store
*.log
.env
.env.*
!.env.example
