{
  "name": "llm-translate",
  "description": "Selection, full-page & screenshot translation powered by your own OpenAI-compatible or Anthropic-compatible LLM API.",
  "private": true,
  "type": "module",
  "version": "0.2.0",
  "packageManager": "pnpm@9.15.9",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "wxt",
    "dev:edge": "wxt -b edge",
    "build": "wxt build",
    "build:edge": "wxt build -b edge",
    "zip": "wxt zip",
    "zip:edge": "wxt zip -b edge",
    "dev:firefox": "wxt -b firefox --mv3",
    "build:firefox": "wxt build -b firefox --mv3",
    "zip:firefox": "wxt zip -b firefox --mv3",
    "verify:firefox": "pnpm build:firefox && node scripts/verify-firefox-manifest.mjs",
    "sign:firefox": "pnpm build:firefox && node scripts/sign-firefox.mjs",
    "e2e:firefox": "pnpm zip:firefox && vitest run --config vitest.e2e-firefox.config.ts",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome check --write .",
    "test": "vitest run",
    "test:watch": "vitest",
    "e2e": "wxt build && playwright test",
    "e2e:ui": "wxt build && playwright test --ui",
    "screenshots": "wxt build && node scripts/screenshots.mjs",
    "postinstall": "wxt prepare"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@playwright/test": "^1.61.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/selenium-webdriver": "^4.35.6",
    "@wxt-dev/module-react": "^1.2.2",
    "happy-dom": "^20.10.6",
    "selenium-webdriver": "^4.45.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10",
    "wxt": "^0.20.27"
  },
  "dependencies": {
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
